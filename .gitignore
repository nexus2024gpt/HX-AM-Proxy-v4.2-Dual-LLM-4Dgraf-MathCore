# HX-AM Proxy v4.2 — .gitignore

# ── Секреты и окружение ───────────────────────────────────────────────────────
.env
venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Конфиг провайдеров (содержит API-ключи) ───────────────────────────────────
config/providers.json
config/api_usage.json
api_usage_tracker.py
# ── Семантические индексы (большие, автогенерируемые) ────────────────────────
artifacts/semantic_index.jsonl
artifacts/four_d_index.jsonl

# ── Граф инвариантов (автогенерируемый) ──────────────────────────────────────
# ВНИМАНИЕ: artifacts/invariant_graph.json ВКЛЮЧЁН в репо (патчим вручную)
# Если хочешь исключить: раскомментируй строку ниже
artifacts/invariant_graph.json

# ── Артефакты (по умолчанию НЕ коммитятся — слишком большие) ─────────────────
# Раскомментируй следующие строки если НЕ хочешь хранить артефакты в git:
artifacts/*.json
artifacts/*.hyx-portal.json
# НО: TRUST-артефакты (seed) коммитятся вручную через git add -f

# ── История чатов и карантин ──────────────────────────────────────────────────
chat_history/

# ── Результаты симуляций (большие, автогенерируемые) ─────────────────────────
sim_results/
mgap_results/
# ── Инсайты (автогенерируемые) ───────────────────────────────────────────────
insights/

# ── Корзина удалённых артефактов ──────────────────────────────────────────────
trash/

# Windows/Google Drive system files
desktop.ini
Thumbs.db
*.tmp
*.lnk
*.gdoc
*.gsheet
*.gslides


# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── Python ───────────────────────────────────────────────────────────────────
*.egg-info/
dist/
build/
.pytest_cache/
.tmp.driveupload
# Ignore test scripts with API keys
test_keys/